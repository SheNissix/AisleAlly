<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView style="@style/PageTitle" android:text="Profile"/>

        <LinearLayout style="@style/Card" android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/et_age"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_field_pill"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:hint="e.g. 25"
                android:inputType="number"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight (kg)"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/et_weight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_field_pill"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:hint="e.g. 65"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Height (cm)"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/et_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_field_pill"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:hint="e.g. 170"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sex"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <ImageView
                    android:id="@+id/ivActivityInfo"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:contentDescription="Activity Info" />
            </LinearLayout>
            <Spinner
                android:id="@+id/spinner_sex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_field_pill"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity Level"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="14dp"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinner_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_field_pill"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btn_generate_targets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_pill"
                android:text="GENERATE NUTRITION TARGETS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:padding="14dp"/>

        </LinearLayout>

        <!-- TARGETS CARD — unchanged -->
        <LinearLayout style="@style/Card" android:orientation="vertical">

            <TextView style="@style/SectionTitle" android:text="Nutritional Targets"/>

            <LinearLayout style="@style/TargetCard" android:orientation="vertical">
                <TextView style="@style/TargetLabel" android:text="Daily Caloric Target"/>
                <TextView android:id="@+id/tv_daily_calories" style="@style/TargetValue" android:text="--"/>
            </LinearLayout>

            <LinearLayout style="@style/TargetCard" android:orientation="vertical">
                <TextView style="@style/TargetLabel" android:text="Minimum Calories"/>
                <TextView android:id="@+id/tv_min_calories" style="@style/TargetValue" android:text="--"/>
            </LinearLayout>

            <LinearLayout style="@style/TargetCard" android:orientation="vertical">
                <TextView style="@style/TargetLabel" android:text="Maximum Calories"/>
                <TextView android:id="@+id/tv_max_calories" style="@style/TargetValue" android:text="--"/>
            </LinearLayout>

            <LinearLayout style="@style/TargetCard" android:orientation="vertical">
                <TextView style="@style/TargetLabel" android:text="Protein (g/day)"/>
                <TextView android:id="@+id/tv_protein_target" style="@style/TargetValue" android:text="--"/>
            </LinearLayout>

            <LinearLayout style="@style/TargetCard" android:orientation="vertical">
                <TextView style="@style/TargetLabel" android:text="Fiber (g/day)"/>
                <TextView android:id="@+id/tv_fiber_target" style="@style/TargetValue" android:text="--"/>
            </LinearLayout>

            <LinearLayout style="@style/TargetCard" android:orientation="vertical">
                <TextView style="@style/TargetLabel" android:text="Fat (g/day)"/>
                <TextView android:id="@+id/tv_fat_target" style="@style/TargetValue" android:text="--"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>